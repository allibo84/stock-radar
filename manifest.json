{
  "manifest_version": 3,
  "name": "Idealo Prix Amazon",
  "version": "1.5",
  "description": "Affiche le prix Amazon sur idealo.fr",
  "host_permissions": ["https://www.idealo.fr/*"],
  "content_scripts": [
    {
      "matches": ["https://www.idealo.fr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}